rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = uid finns i config/admins.uids (redigeras endast via konsolen).
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/config/admins)
             && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    match /config/admins {
      // Bara admins kan läsa listan; ingen klient kan skriva den.
      allow get: if request.auth != null && request.auth.uid in resource.data.uids;
    }

    // ===== Användare & vänner (befintliga funktioner) =====

    match /users/{userId} {
      // Handles måste kunna slås upp för vänförfrågningar; profiler innehåller
      // bara displayName/handle/email.
      allow read: if request.auth != null;
      // Nytt/ändrat handle måste vara registrerat på skrivaren i handle-
      // registret I SAMMA batch (getAfter) — det är detta som gör
      // @användarnamn unika på riktigt (dokument-ID:t är namnet).
      function handleClaimed() {
        return getAfter(/databases/$(database)/documents/handles/$(request.resource.data.handle)).data.uid == request.auth.uid;
      }
      // instructor sätts ENDAST av servern (adminSetInstructor) och
      // friendCount ENDAST av onFriendsChanged — klienter får aldrig skriva
      // dem, inte ens på sitt eget dokument (annars kan antalet förfalskas).
      allow create: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny(['instructor', 'friendCount'])
                    && (!('handle' in request.resource.data) || handleClaimed());
      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['instructor', 'friendCount'])
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['handle']) || handleClaimed());

      match /friends/{friendId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // Båda sidorna av vänskapen skrivs av den som accepterar förfrågan.
        allow create: if request.auth != null
                      && (request.auth.uid == userId || request.auth.uid == friendId);
        allow delete: if request.auth != null
                      && (request.auth.uid == userId || request.auth.uid == friendId);
      }

      // Profilinlägg: ägaren skriver, ägaren + vänner läser.
      match /posts/{postId} {
        allow read: if (request.auth != null
                        && (request.auth.uid == userId
                            || exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))))
                    || isAdmin();
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.authorUid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();

        // Reaktioner (🐾): den som kan läsa inlägget kan gilla; man styr bara sin egen.
        match /reactions/{reactorUid} {
          allow read: if request.auth != null
                      && (request.auth.uid == userId
                          || exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid)));
          allow create, delete: if request.auth != null && request.auth.uid == reactorUid;
        }

        // Kommentarer: läsare kan kommentera; man raderar egen (eller inläggsägaren).
        match /comments/{commentId} {
          allow read: if request.auth != null
                      && (request.auth.uid == userId
                          || exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid)));
          allow create: if request.auth != null
                        && request.resource.data.authorUid == request.auth.uid;
          allow delete: if (request.auth != null
                            && (resource.data.authorUid == request.auth.uid || request.auth.uid == userId))
                        || isAdmin();
        }
      }

      // Push-token per enhet (för notiser).
      match /fcmTokens/{token} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Blockerade användare (endast ägaren ser och hanterar sin lista).
      match /blocked/{blockedUid} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== Handle-register: unika @användarnamn =====
    // Dokument-ID:t ÄR handlet, så två användare kan aldrig registrera samma
    // namn. users-reglerna kräver via getAfter att profilens handle är
    // registrerat på skrivaren i samma atomiska batch. Konton från innan
    // registret backfillas av adminBackfillHandles.
    match /handles/{handle} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      // update: aldrig — ett handle byter inte ägare, det släpps och tas om.
    }

    // Anmälningar av innehåll: vem som helst inloggad kan skapa sin egen;
    // admins läser och hanterar kön i appen.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, delete: if isAdmin();
    }

    // Enhets-token-register. Dokument-ID:t är FCM-token — bara enheten som
    // har token känner till det, så innehav av ID:t är behörigheten.
    // INGEN list: annars kan en inloggad användare skörda alla tokens.
    // En post får bara knytas till det egna kontot; servern (admin-SDK,
    // onDeviceTokenClaimed) städar gamla kontokopplingar.
    match /deviceTokens/{token} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update: if request.auth != null
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // Privat molnbackup per användare (t.ex. träningspass-biblioteket). Bara
    // ägaren själv når sitt eget område — aldrig någon annan, aldrig admin.
    match /userBackups/{ownerUid}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == ownerUid;
    }

    // Supportärenden: användaren skapar och ser sina egna; admin hanterar alla.
    match /supportTickets/{ticketId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'open';
      allow read: if isAdmin()
                  || (request.auth != null && request.auth.uid == resource.data.uid);
      allow update, delete: if isAdmin();
    }

    // ===== Forum (öppet för alla inloggade) =====

    match /forum/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.replyCount == 0;
      // Vid svar behöver vem som helst kunna räkna upp replyCount/aktivitet,
      // men inget annat på tråden får röras av andra än författaren/admin —
      // och räknaren får bara stega ±1 (klienten gör increment(±1)), inte
      // sättas till godtyckliga värden på andras trådar.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['replyCount', 'lastActivityAt'])
                    && (request.resource.data.replyCount == resource.data.replyCount + 1
                        || request.resource.data.replyCount == resource.data.replyCount - 1)
                    && request.resource.data.replyCount >= 0;
      allow delete: if (request.auth != null && request.auth.uid == resource.data.authorUid)
                    || isAdmin();

      match /replies/{replyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorUid == request.auth.uid;
        allow delete: if (request.auth != null && request.auth.uid == resource.data.authorUid)
                      || isAdmin();
      }
    }

    // ===== Team & hundträffar =====

    match /teams/{teamId} {
      allow read: if (request.auth != null && request.auth.uid in resource.data.memberUids) || isAdmin();
      // Kurs- och konsulentteam kräver instruktörskonto (flaggan sätts bara
      // av servern). Vanliga grupper (social, eller äldre appversioner utan
      // typ-fält) är öppna för alla.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid
                    && request.auth.uid in request.resource.data.memberUids
                    && (!(request.resource.data.get('teamType', 'social') in ['course', 'consulting'])
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('instructor', false) == true);
      // Ägaren hanterar teamet; en medlem får lämna; en inbjuden användare
      // får lägga till sig själv om en väntande inbjudan finns.
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.ownerUid
                        || (request.auth.uid in resource.data.memberUids
                            && !(request.auth.uid in request.resource.data.memberUids)
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'memberNames']))
                        || (!(request.auth.uid in resource.data.memberUids)
                            && request.auth.uid in request.resource.data.memberUids
                            && request.resource.data.memberUids.hasAll(resource.data.memberUids)
                            && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'memberNames'])
                            && get(/databases/$(database)/documents/teamInvites/$(teamId + '_' + request.auth.uid)).data.status == 'pending'));
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;

      // Team-inlägg: bara medlemmar ser och skriver.
      match /posts/{postId} {
        function isTeamMember() {
          return request.auth != null
                 && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.memberUids;
        }

        allow read: if isTeamMember() || isAdmin();
        allow create: if isTeamMember() && request.resource.data.authorUid == request.auth.uid;
        allow delete: if (request.auth != null
                          && (resource.data.authorUid == request.auth.uid
                              || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid))
                      || isAdmin();

        match /reactions/{reactorUid} {
          allow read: if isTeamMember();
          allow create, delete: if isTeamMember() && request.auth.uid == reactorUid;
        }

        match /comments/{commentId} {
          allow read: if isTeamMember();
          allow create: if isTeamMember() && request.resource.data.authorUid == request.auth.uid;
          allow delete: if (request.auth != null && resource.data.authorUid == request.auth.uid) || isAdmin();
        }
      }

      // Uppgifter: ägaren/konsulenter lägger ut, varje medlem bockar av sig själv.
      match /tasks/{taskId} {
        function teamData() {
          return get(/databases/$(database)/documents/teams/$(teamId)).data;
        }
        function isMember() {
          return request.auth != null && request.auth.uid in teamData().memberUids;
        }
        function canManageTasks() {
          return request.auth != null
                 && (request.auth.uid == teamData().ownerUid
                     || request.auth.uid in teamData().get('consultantUids', []));
        }

        allow read: if isMember() || isAdmin();
        allow create: if canManageTasks() && request.resource.data.createdByUid == request.auth.uid;
        // Medlemmar får bara ändra completedUids, och bara lägga till/ta bort sitt eget uid.
        allow update: if isMember()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedUids'])
                      && request.resource.data.completedUids.toSet().difference(resource.data.completedUids.toSet()).hasOnly([request.auth.uid])
                      && resource.data.completedUids.toSet().difference(request.resource.data.completedUids.toSet()).hasOnly([request.auth.uid]);
        // Ägare/konsulenter (eller skaparen) får redigera innehållet, men aldrig
        // skaparfälten eller andras avbockningar.
        allow update: if (canManageTasks() || resource.data.createdByUid == request.auth.uid)
                      && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['createdByUid', 'createdByName', 'createdAt', 'completedUids']);
        allow delete: if canManageTasks()
                      || (request.auth != null && resource.data.createdByUid == request.auth.uid)
                      || isAdmin();
      }
    }

    // Inbjudningskoder till team: en per team (dok-id = teamId). Ägare och
    // konsulenter skapar/byter koden; medlemmar kan läsa den för att dela.
    // Själva anslutningen sker via Cloud Function (admin), aldrig direkt.
    match /teamJoinCodes/{teamId} {
      function teamData() {
        return get(/databases/$(database)/documents/teams/$(teamId)).data;
      }
      allow read: if request.auth != null
                  && request.auth.uid in teamData().memberUids;
      allow create, update, delete: if request.auth != null
                  && (request.auth.uid == teamData().ownerUid
                      || request.auth.uid in teamData().get('consultantUids', []));
    }

    // Öppna stadsgrupper. Städerna själva är en statisk lista i appen; det
    // enda som lever här är en publik medlemsräknare per stad plus de privata
    // medlemskapen.
    match /communities/{communityId} {
      // Bara räknaren (memberCount) — publik för alla inloggade. Skrivs bara
      // av Cloud Function-triggern (admin-SDK går förbi reglerna); klienten
      // rör den aldrig.
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /communities/{communityId}/members/{memberUid} {
      // Namnen är privata: man får bara läsa sitt EGET medlemskap (för att veta
      // om man är med). Ingen kan lista medlemmarna eller läsa någon annans —
      // därför räknas medlemmarna via räknaren ovan, inte via count() här.
      allow get: if request.auth != null && (request.auth.uid == memberUid || isAdmin());
      allow list: if isAdmin();
      // Man skapar/tar bara bort sitt EGET medlemskap (dok-id = uid), och
      // dokumentets uid måste vara ens egen — ingen kan gå med åt någon annan.
      allow create: if request.auth != null
                    && request.auth.uid == memberUid
                    && request.resource.data.uid == memberUid;
      allow delete: if (request.auth != null && request.auth.uid == memberUid) || isAdmin();
      // Medlemskap ändras inte — man går med eller lämnar.
      allow update: if false;
    }

    match /teamInvites/{inviteId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.toUid
                      || request.auth.uid == resource.data.fromUid);
      // Bara teamets ägare bjuder in, med deterministiskt ID och pending-status.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.status == 'pending'
                    && inviteId == request.resource.data.teamId + '_' + request.resource.data.toUid
                    && request.auth.uid == get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.ownerUid;
      // Mottagaren svarar (bara status), avsändaren kan dra tillbaka/förnya.
      allow update: if request.auth != null
                    && ((request.auth.uid == resource.data.toUid
                         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
                        || (request.auth.uid == resource.data.fromUid
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'createdAt'])));
      allow delete: if request.auth != null && request.auth.uid == resource.data.fromUid;
    }

    match /meetups/{meetupId} {
      function meetupTeam() {
        return get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data;
      }
      // Är den inloggade medlem i stadsgruppen träffen hör till?
      function isCommunityMember(data) {
        return data.get('communityId', '') != ''
               && exists(/databases/$(database)/documents/communities/$(data.communityId)/members/$(request.auth.uid));
      }
      // Stadsträffar är öppna att se för alla inloggade (upptäckt innan man går
      // med); team-/vänträffar bara för ägare och inbjudna.
      allow read: if (request.auth != null
                      && (request.auth.uid == resource.data.ownerUid
                          || request.auth.uid in resource.data.invitedUids
                          || resource.data.get('communityId', '') != ''))
                  || isAdmin();
      // Team-träffar: i kurser/konsulentteam får bara ägare/konsulenter skapa;
      // i vanliga grupper alla medlemmar. Stadsträffar: alla stadens medlemmar.
      // Träffar utan team eller community är fria.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerUid
                    && ((request.resource.data.get('teamId', '') == ''
                         && request.resource.data.get('communityId', '') == '')
                        || isCommunityMember(request.resource.data)
                        || (request.resource.data.get('teamId', '') != ''
                            && request.auth.uid in meetupTeam().memberUids
                            && (meetupTeam().get('teamType', '') == 'social'
                                || request.auth.uid == meetupTeam().ownerUid
                                || request.auth.uid in meetupTeam().get('consultantUids', []))));
      // RSVP-arrayerna: bara det EGNA uid:t får läggas till/tas bort —
      // annars kan en inbjuden skriva in eller radera ANDRAS svar
      // (t.ex. fylla en kurs med falska deltagare).
      function rsvpSelfOnly(field) {
        return request.resource.data.get(field, []).toSet()
                 .difference(resource.data.get(field, []).toSet())
                 .hasOnly([request.auth.uid])
            && resource.data.get(field, []).toSet()
                 .difference(request.resource.data.get(field, []).toSet())
                 .hasOnly([request.auth.uid]);
      }
      // invitedUids: man får lägga till SIG SJÄLV (öppna stadsträffar — så
      // träffen syns i ens egen träfflista/påminnelser), aldrig ta bort någon.
      function invitedAddSelfOnly() {
        return request.resource.data.get('invitedUids', []).toSet()
                 .difference(resource.data.get('invitedUids', []).toSet())
                 .hasOnly([request.auth.uid])
            && resource.data.get('invitedUids', []).toSet()
                 .difference(request.resource.data.get('invitedUids', []).toSet())
                 .size() == 0;
      }
      // maxSpots: att lägga till sig själv i goingUids kräver ledig plats.
      // Reglerna utvärderas mot senast committade dokumentet, så två
      // samtidiga "sista platsen"-svar kan inte längre överboka.
      function withinCapacity() {
        return resource.data.get('maxSpots', 0) == 0
            || request.auth.uid in resource.data.get('goingUids', [])
            || !(request.auth.uid in request.resource.data.get('goingUids', []))
            || request.resource.data.get('goingUids', []).size() <= resource.data.get('maxSpots', 0);
      }
      // Ägaren ändrar allt; inbjudna och stadens medlemmar svarar (going/
      // declined), får lägga till sig i invitedUids och skriva sitt EGET
      // namn i invitedNames — inte någon annans, och inga andra fält.
      // get(..., {}) på invitedNames: stadsträffar kan sakna fältet helt.
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.ownerUid
                        || ((request.auth.uid in resource.data.invitedUids
                             || isCommunityMember(resource.data))
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['goingUids', 'declinedUids', 'invitedUids', 'invitedNames'])
                            && rsvpSelfOnly('goingUids')
                            && rsvpSelfOnly('declinedUids')
                            && invitedAddSelfOnly()
                            && withinCapacity()
                            && request.resource.data.get('invitedNames', {}).diff(resource.data.get('invitedNames', {})).affectedKeys().hasOnly([request.auth.uid])));
      // Admin behöver kunna ta bort rapporterade träffar.
      allow delete: if (request.auth != null && request.auth.uid == resource.data.ownerUid)
                    || isAdmin();
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUid
                      || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUid
                    && request.resource.data.status == 'pending';
      // Endast mottagaren svarar, och får bara ändra status.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.toUid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // ===== Delade hundar =====

    match /shares/{shareId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.ownerUid
                      || request.auth.uid == resource.data.recipientUid);
      // Ägaren skapar/ändrar; dokument-ID:t måste vara {dogRemoteID}_{recipientUid}
      // eftersom reglerna för sharedDogs slår upp exakt den sökvägen.
      allow create, update: if request.auth != null
                            && request.auth.uid == request.resource.data.ownerUid
                            && shareId == request.resource.data.dogRemoteID + '_' + request.resource.data.recipientUid;
      // Ägaren återkallar — och mottagaren får ta bort delningen från sin sida.
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.ownerUid
                        || request.auth.uid == resource.data.recipientUid);
    }

    match /sharedDogs/{dogId} {
      function myShareExists() {
        return exists(/databases/$(database)/documents/shares/$(dogId + '_' + request.auth.uid));
      }
      function myShare() {
        return get(/databases/$(database)/documents/shares/$(dogId + '_' + request.auth.uid)).data;
      }
      function dogOwnerUid() {
        return get(/databases/$(database)/documents/sharedDogs/$(dogId)).data.ownerUid;
      }

      // OBS: myShareExists() utvärderas FÖRST — den rör inte resource och
      // fungerar även när dokumentet saknas (fel i OR-grenar smittar i regler).
      allow read: if request.auth != null
                  && (myShareExists()
                      || (resource != null && request.auth.uid == resource.data.ownerUid));
      allow create, update: if request.auth != null
                            && request.auth.uid == request.resource.data.ownerUid;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;

      match /{module}/{entryId} {
        // Subkollektionerna heter t.ex. "healthEvents" men share-dokumentets
        // modules-lista lagrar nycklarna ("health" …) — översätt innan jämförelse.
        function moduleKey() {
          return module == 'healthEvents' ? 'health'
               : module == 'heatCycles' ? 'heat'
               : module == 'diaryEntries' ? 'diary'
               : module == 'mealEntries' ? 'meals'
               : module == 'trainingSessions' ? 'training'
               : module;
        }

        // Ägaren läser/skriver allt; mottagare läser moduler i sin share,
        // och skriver bara med readWrite + eget författarskap.
        // Share-grenen utvärderas FÖRST: dogOwnerUid() kraschar (→ deny)
        // om hunddokumentet saknas, och fel i OR-grenar smittar i regler.
        allow read: if request.auth != null
                    && ((myShareExists() && moduleKey() in myShare().modules)
                        || request.auth.uid == dogOwnerUid());
        allow create, update: if request.auth != null
                              && ((myShareExists()
                                   && myShare().permission == 'readWrite'
                                   && moduleKey() in myShare().modules
                                   && request.resource.data.createdByUid == request.auth.uid)
                                  || request.auth.uid == dogOwnerUid());
        // Delete saknar request.resource — författarskapet läses från resource.
        allow delete: if request.auth != null
                      && ((myShareExists()
                           && myShare().permission == 'readWrite'
                           && moduleKey() in myShare().modules
                           && resource.data.createdByUid == request.auth.uid)
                          || request.auth.uid == dogOwnerUid());
      }
    }
  }
}

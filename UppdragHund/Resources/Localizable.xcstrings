    "Planerar du parning? Boka progesteronprov — det tas runt dygn %lld." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Planning a mating? Book a progesterone test — it's taken around day %lld." } } }
    },

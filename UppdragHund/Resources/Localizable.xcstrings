    },
    "Ändra genvägar" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Edit shortcuts" } } }
    },
    "Valda genvägar visas på Hem. Tryck för att lägga till eller ta bort." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Selected shortcuts appear on Home. Tap to add or remove." } } }
    },
    "Klar" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Done" } } }
    },
    "Dra i handtagen för att ändra ordning. Bocka av ett block för att dölja det på Hem." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Drag the handles to reorder. Uncheck a block to hide it on Home." } } }
    },
    "Idag" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Today" } } }
    },
    "Idag, %@" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Today, %@" } } }
    },
    "Träff idag: %@ kl %@" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Meetup today: %1$@ at %2$@" } } }
    },
    "Nästa träff: %@, %@" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Next meetup: %1$@, %2$@" } } }
    },
    "%@: 1 uppgift att bocka av" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%@: 1 task to check off" } } }
    },
    "%@: %lld uppgifter att bocka av" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%1$@: %2$lld tasks to check off" } } }
    },
    "Allt ser bra ut idag 🐾" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Everything looks good today 🐾" } } }
    },
    "God morgon! Redo för dagen med %@?" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Good morning! Ready for the day with %@?" } } }
    },
    "God eftermiddag med %@ 🐾" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Good afternoon with %@ 🐾" } } }
    },
    "God kväll! Hur har dagen med %@ varit?" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Good evening! How was your day with %@?" } } }
    },
    "God natt – vila så ni orkar imorgon 🐾" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Good night – rest up for tomorrow 🐾" } } }
    },
    "🎂 Grattis %@ – %lld år idag!" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "🎂 Happy birthday %1$@ – turning %2$lld today!" } } }
    },
    "🎂 %@ fyller %lld år imorgon" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "🎂 %1$@ turns %2$lld tomorrow" } } }
    },
    "🎂 %@ fyller %lld år om %lld dagar" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "🎂 %1$@ turns %2$lld in %3$lld days" } } }
    },
    "Tips: variera promenadrutten – nya dofter tröttar hjärnan mer än extra minuter." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: vary your walking route – new scents tire the brain more than extra minutes." } } }
    },
    "Tips: kolla tassarna efter promenaden, särskilt mellan trampdynorna." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: check the paws after the walk, especially between the pads." } } }
    },
    "Tips: korta träningspass flera gånger om dagen slår ett långt." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: several short training sessions a day beat one long one." } } }
    },
    "Tips: färskt vatten alltid framme – särskilt varma dagar." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: always keep fresh water out – especially on warm days." } } }
    },
    "Tips: väg din hund regelbundet, små förändringar syns tidigast på vågen." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: weigh your dog regularly – small changes show up on the scale first." } } }
    },
    "Tips: borsta tänderna eller ge tuggben – tandhälsa påverkar hela hunden." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: brush the teeth or give a chew – dental health affects the whole dog." } } }
    },
    "Tips: låt hunden nosa klart ibland, det är mental motion." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Tip: let your dog finish sniffing sometimes – it's mental exercise." } } }
    },
    "%lld min motion loggad idag" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%lld min of exercise logged today" } } }
    },
    "Ingen promenad loggad än — dags för en runda med %@?" : {

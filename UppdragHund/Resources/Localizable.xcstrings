  "strings" : {
    "Alla block är dolda. Tryck här för att anpassa hem." : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "All blocks are hidden. Tap here to customize Home." } } }
    },
    "Anpassa hem" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Customize Home" } } }
    },
    "Anpassa hem med ⊞ där uppe 👆" : {
      "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Customize Home with ⊞ up there 👆" } } }
    },

{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8089
    },
    "ui": {
      "enabled": false
    }
  },
  "hosting": {
    "public": "web",
    "ignore": ["firebase.json", "**/.*"]
  }
}
